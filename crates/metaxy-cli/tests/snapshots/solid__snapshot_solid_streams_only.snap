}

const VOID_STREAM_KEYS: Set<StreamKey> = new Set(["events"]);

export function createStream<K extends "events">(client: RpcClient, key: K, options?: StreamOptions<K>): StreamResult<K>;
export function createStream<K extends "chat">(client: RpcClient, key: K, input: () => StreamInput<K>, options?: StreamOptions<K>): StreamResult<K>;
export function createStream<K extends StreamKey>(
  client: RpcClient,
  ...args: unknown[]
